## 6. Real-world examples

### Web app-style example: save a config file

```ts
import { writeFile, readFile } from "node:fs/promises";

const siteName = "My First App";
const theme = "dark";

await writeFile(
  "config.txt",
  `site_name=${siteName}\ntheme=${theme}\n`,
  "utf8"
);

const config = await readFile("config.txt", "utf8");
console.log(config);
```

### Automation example: save task list

```ts
import { writeFile } from "node:fs/promises";

const tasks: string[] = ["email client", "backup files", "update report"];
await writeFile("tasks.txt", tasks.join("\n") + "\n", "utf8");
```

### Scientific example: save measurements

```ts
import { writeFile } from "node:fs/promises";

const measurements: number[] = [21.5, 22.1, 21.8];
await writeFile(
  "measurements.txt",
  measurements.join("\n") + "\n",
  "utf8"
);
```

